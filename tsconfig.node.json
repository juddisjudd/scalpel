{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": ["src/main/**/*", "src/preload/**/*", "src/shared/**/*", "src/plugin-sdk/**/*", "electron.vite.config.ts"],
  "exclude": ["src/plugin-sdk/dist/**", "src/plugin-sdk/node_modules/**"]
}
